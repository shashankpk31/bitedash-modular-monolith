# ==========================================
# BiteDash Frontend - .gitignore
# ==========================================

# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
build/
.vite/

# Environment (use .env.example as template)
.env
.env.*
!.env.example
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test coverage
coverage/
.nyc_output/

# Editor/IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db

# Temporary
*.tmp
*.temp
.cache/

# PWA generated files (auto-generated, don't need to commit)
dev-dist/
