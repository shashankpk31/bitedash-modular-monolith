# ==========================================
# BiteDash Backend - .gitignore
# ==========================================

# ==========================================
# Maven Build
# ==========================================
target/
**/target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties

# Keep Maven wrapper for CI/CD
# .mvn/
# mvnw
# mvnw.cmd

# ==========================================
# Compiled Files
# ==========================================
*.class
*.jar
*.war
*.ear
*.nar

# ==========================================
# IDE & Editors
# ==========================================
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# Eclipse / STS
.classpath
.project
.settings/
.metadata/
bin/
.factorypath
.apt_generated/
.apt_generated_tests/
.springBeans

# VS Code
.vscode/

# ==========================================
# Environment & Secrets
# ==========================================
.env
.env.*
!.env.example

# Local config files
application-local.yml
application-local.properties
bite-env.sh

# Secrets
*.pem
*.key
*.cert
*.p12
*.jks
secrets/

# ==========================================
# Logs & Debug
# ==========================================
*.log
logs/
spring.log
debug.log
error.txt

# ==========================================
# Database Files
# ==========================================
*.db
*.mv.db
*.trace.db
*.sqlite
data/

# ==========================================
# Test Reports
# ==========================================
**/surefire-reports/
**/failsafe-reports/
coverage/
htmlcov/

# ==========================================
# OS Files
# ==========================================
.DS_Store
Thumbs.db
desktop.ini

# ==========================================
# Temporary
# ==========================================
*.tmp
*.bak
*.swp
*~
.cache/

# ==========================================
# Package Archives
# ==========================================
*.zip
*.tar.gz
*.rar

# ==========================================
# Keep Important Files
# ==========================================
!README.md
!RUNNING_IN_IDE.md
!.env.example
!Dockerfile
!docker-compose*.yml
